{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user basic information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "CreativeTask": {
      "title": "Creative Asset Task",
      "description": "Represents a media generation task (image/video/anime/film).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "music", "image", "anime", "film"] },
        "prompt": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed"] },
        "resultUrl": { "type": "string" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "prompt", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in the Aether AI conversation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai", "system"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/users/{userId}/creative_tasks/{taskId}": {
      "schema": "CreativeTask",
      "description": "The collection of creative media generated by the user."
    },
    "/users/{userId}/chat_history/{messageId}": {
      "schema": "ChatMessage",
      "description": "Persistent chat history between the user and Aether AI."
    }
  }
}
